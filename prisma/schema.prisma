generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  TEACHER
  MODERATOR
}

enum AppStatus {
  ACTIVE
  DISABLED
  COMING_SOON
}

enum PaymentStatus {
  PENDING
  WAITING_VERIFICATION
  PAID
  REJECTED
  EXPIRED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELED
}

enum ReadingSourceType {
  CACHED
  AI_GENERATED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  avatarUrl     String?

  learningReminderEnabled Boolean @default(false)
  learningReminderTime    String?
  learningGoal            String?

  role UserRole @default(USER)

  appAccess               AppUserAccess[]
  lessonAccess            LessonAccess[]
  payments                PaymentTransaction[]
  subscriptions           Subscription[]
  paymentProofs           PaymentProof[]
  featureUsage            FeatureUsage[]
  accessAudits            AccessGrantAudit[]               @relation("AccessAuditActor")
  accounts                Account[]
  sessions                Session[]
  nihongoProfile          UserNihongoProfile?
  nihongoAssessments      NihongoAssessmentSession[]
  nihongoBadges           UserNihongoBadge[]
  nihongoMockAttempts     NihongoMockTestAttempt[]
  gameProfile             UserGameProfile?
  gameKingdom             GameKingdom?
  gameResourceLedgers     GameResourceLedger[]             @relation("GameLedgerUser")
  gameDailyCounters       GameLearningRewardDailyCounter[]
  communityRoomsCreated   CommunityRoom[]                  @relation("CommunityRoomCreator")
  communityMessages       CommunityMessage[]               @relation("CommunityMessageAuthor")
  communityReactions      CommunityMessageReaction[]       @relation("CommunityReactionUser")
  englishInterviewAnswers EnglishInterviewAnswer[]
  englishInterviewReviews EnglishInterviewReview[]         @relation("EnglishInterviewReviewer")
  analyticsEvents         AnalyticsEvent[]
  courseCertificates      CourseCertificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityRoom {
  id          String  @id @default(cuid())
  name        String
  description String?
  createdById String

  createdBy      User               @relation("CommunityRoomCreator", fields: [createdById], references: [id], onDelete: Cascade)
  messages       CommunityMessage[] @relation("CommunityRoomMessages")
  linkedMessages CommunityMessage[] @relation("LinkedCommunityRoom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([createdAt])
}

model GameKingdom {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  name                     String
  continent                String
  level                    Int       @default(1)
  castleLevel              Int       @default(1)
  xp                       Int       @default(0)
  resourcesJson            Json
  heroKey                  String    @default("ARJUNA")
  heroSelectedAt           DateTime?
  selectedAttackWeaponKey  String    @default("MOONLIGHT_KUNAI_STORM")
  selectedDefenseWeaponKey String    @default("SILVER_MOON_TOWER")
  shieldUntil              DateTime?
  lastDailyLoginRewardAt   DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers              GameResourceLedger[]
  armyUnits            GameArmyUnit[]
  battleLogsAsAttacker GameBattleLog[]      @relation("GameBattleAttacker")
  battleLogsAsDefender GameBattleLog[]      @relation("GameBattleDefender")
  cards                GameUserCard[]

  @@index([continent])
  @@index([xp])
  @@index([castleLevel])
}

model GameResourceLedger {
  id            String   @id @default(cuid())
  userId        String
  kingdomId     String
  sourceKey     String
  sourceType    String
  resourcesJson Json
  xp            Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())

  user    User        @relation("GameLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  kingdom GameKingdom @relation(fields: [kingdomId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceKey])
  @@index([kingdomId])
  @@index([sourceType])
  @@index([createdAt])
}

model GameArmyUnit {
  id              String   @id @default(cuid())
  kingdomId       String
  unitKey         String
  quantity        Int      @default(0)
  defenseQuantity Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  kingdom GameKingdom @relation(fields: [kingdomId], references: [id], onDelete: Cascade)

  @@unique([kingdomId, unitKey])
  @@index([kingdomId])
}

model GameBattleLog {
  id                       String    @id @default(cuid())
  attackerKingdomId        String
  defenderKingdomId        String
  continent                String
  result                   String
  attackerPower            Int
  defenderPower            Int
  stolenResourcesJson      Json
  casualtiesJson           Json
  attackerCasualtiesJson   Json?
  defenderCasualtiesJson   Json?
  snapshotJson             Json
  defenderSeenAt           DateTime?
  createdAt                DateTime  @default(now())

  attacker GameKingdom @relation("GameBattleAttacker", fields: [attackerKingdomId], references: [id], onDelete: Cascade)
  defender GameKingdom @relation("GameBattleDefender", fields: [defenderKingdomId], references: [id], onDelete: Cascade)

  @@index([attackerKingdomId])
  @@index([defenderKingdomId])
  @@index([continent])
  @@index([createdAt])
  @@index([defenderKingdomId, defenderSeenAt])
}

model GameUserCard {
  id        String   @id @default(cuid())
  kingdomId String
  cardKey   String
  quantity  Int      @default(1)
  equipped  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kingdom GameKingdom @relation(fields: [kingdomId], references: [id], onDelete: Cascade)

  @@unique([kingdomId, cardKey])
  @@index([kingdomId])
}

model GameLearningRewardDailyCounter {
  id             String   @id @default(cuid())
  userId         String
  counterDate    String
  flashcardCount Int      @default(0)
  quizCount      Int      @default(0)
  mockCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, counterDate])
  @@index([counterDate])
}

model CommunityMessage {
  id           String  @id @default(cuid())
  roomId       String
  authorId     String
  body         String
  replyToId    String?
  linkedRoomId String?

  room       CommunityRoom              @relation("CommunityRoomMessages", fields: [roomId], references: [id], onDelete: Cascade)
  author     User                       @relation("CommunityMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replyTo    CommunityMessage?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies    CommunityMessage[]         @relation("MessageReplies")
  linkedRoom CommunityRoom?             @relation("LinkedCommunityRoom", fields: [linkedRoomId], references: [id])
  reactions  CommunityMessageReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([authorId])
  @@index([replyToId])
  @@index([linkedRoomId])
  @@index([createdAt])
}

model CommunityMessageReaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  type      String @default("ONIGIRI")

  message CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation("CommunityReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId, type])
  @@index([messageId])
  @@index([userId])
}

model AnalyticsEvent {
  id            String  @id @default(cuid())
  userId        String?
  sessionId     String?
  eventType     String
  appSlug       String? @default("nihongo")
  pagePath      String?
  lessonId      String?
  quizId        String?
  flashcardDeck String?
  metadata      Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([appSlug])
  @@index([pagePath])
  @@index([lessonId])
  @@index([quizId])
  @@index([flashcardDeck])
  @@index([createdAt])
}

model PlatformApp {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  status      AppStatus @default(ACTIVE)

  users         AppUserAccess[]
  plans         SubscriptionPlan[]
  payments      PaymentTransaction[]
  subscriptions Subscription[]
  accessAudits  AccessGrantAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  label       String
  value       String?
  valueType   String  @default("TEXT")
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppUserAccess {
  id     String @id @default(cuid())
  userId String
  appId  String

  status          String    @default("ACTIVE")
  billingPlan     String    @default("TRIAL")
  billingPeriod   String    @default("MONTHLY")
  accessStartsAt  DateTime  @default(now())
  accessExpiresAt DateTime?
  lastOpenedAt    DateTime?

  user User        @relation(fields: [userId], references: [id])
  app  PlatformApp @relation(fields: [appId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, appId])
}

model SubscriptionPlan {
  id           String  @id @default(cuid())
  appId        String
  name         String
  code         String
  description  String?
  priceCents   Int
  currency     String  @default("IDR")
  durationDays Int
  billingPeriod String  @default("MONTHLY")
  active       Boolean @default(true)

  app           PlatformApp          @relation(fields: [appId], references: [id], onDelete: Cascade)
  payments      PaymentTransaction[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, code])
  @@index([billingPeriod])
}

model Subscription {
  id     String  @id @default(cuid())
  userId String
  appId  String
  planId String?

  status     SubscriptionStatus @default(TRIAL)
  startedAt  DateTime           @default(now())
  expiresAt  DateTime?
  canceledAt DateTime?

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  app  PlatformApp       @relation(fields: [appId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan? @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([appId])
  @@index([status])
}

model PaymentTransaction {
  id     String  @id @default(cuid())
  userId String
  appId  String
  planId String?

  provider     String    @default("MANUAL")
  providerRef  String?
  status       String    @default("PENDING")
  amountCents  Int
  currency     String    @default("IDR")
  durationDays Int
  paidAt       DateTime?
  rawPayload   String?

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  app   PlatformApp       @relation(fields: [appId], references: [id], onDelete: Cascade)
  plan  SubscriptionPlan? @relation(fields: [planId], references: [id])
  proof PaymentProof?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerRef])
}

model PaymentProof {
  id        String @id @default(cuid())
  paymentId String @unique
  userId    String

  fileUrl      String
  fileName     String?
  fileMimeType String?
  note         String?
  status       String    @default("WAITING_VERIFICATION")
  reviewedBy   String?
  reviewedAt   DateTime?

  payment PaymentTransaction @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model CourseCertificate {
  id            String   @id @default(cuid())
  userId        String
  appSlug       String
  courseName    String
  displayName   String
  certificateId String   @unique
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appSlug, courseName])
  @@index([userId])
  @@index([appSlug])
}

model LessonAccess {
  id       String @id @default(cuid())
  userId   String
  lessonId String

  status    String    @default("ACTIVE")
  grantedBy String?
  expiresAt DateTime?

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model AccessGrantAudit {
  id       String  @id @default(cuid())
  actorId  String?
  userId   String
  appId    String?
  lessonId String?
  action   String
  reason   String?
  metadata String?

  actor User?        @relation("AccessAuditActor", fields: [actorId], references: [id])
  app   PlatformApp? @relation(fields: [appId], references: [id])

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model NihongoLesson {
  id          String  @id @default(cuid())
  slug        String? @unique
  level       String
  title       String
  description String?
  order       Int
  track       String?
  module      String?
  lessonType  String?

  progress               NihongoLessonProgress[]
  access                 LessonAccess[]
  recommendedForProfiles UserNihongoProfile[]            @relation("NextNihongoLesson")
  templates              NihongoLessonTemplate[]
  generatedContents      NihongoLessonGeneratedContent[]
  tutorMessages          NihongoLessonTutorMessage[]
  listeningAsset         NihongoLessonListeningAsset?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoCharacterContent {
  id         String  @id @default(cuid())
  type       String
  level      String
  lessonSlug String
  char       String
  romaji     String?
  onyomi     String?
  kunyomi    String?
  meaning    String?
  order      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, level, char])
  @@index([lessonSlug])
  @@index([type, level])
}

model NihongoLessonProgress {
  id        String  @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model NihongoFlashcard {
  id String @id @default(cuid())

  category String
  deck     String
  level    String
  front    String
  back     String
  example  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoAssessmentSession {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("IN_PROGRESS")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  overallScore               Int?
  estimatedLevel             String?
  weaknessTags               String[]
  strengthTags               String[]
  recommendedCurriculumFocus String[]
  recommendedLessonIds       String[]
  recommendedDailyPlan       String?
  aiFeedbackIndonesian       String?
  encouragementJapanese      String?
  badgeId                    String?
  finalEvaluation            Json?

  pronunciationScore    Int?
  pronunciationFeedback Json?

  user    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers NihongoAssessmentAnswer[]
  badge   NihongoBadge?             @relation(fields: [badgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model NihongoAssessmentAnswer {
  id            String   @id @default(cuid())
  sessionId     String
  questionId    String
  category      String
  type          String
  prompt        String
  userAnswer    String?
  correctAnswer String?
  isCorrect     Boolean?
  score         Int      @default(0)
  maxScore      Int      @default(1)
  metadata      Json?

  session NihongoAssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([category])
}

model AssessmentQuestion {
  id            String   @id @default(cuid())
  level         String
  skill         String
  questionType  String
  prompt        String
  passage       String?
  options       Json
  correctAnswer String
  explanation   String
  difficulty    Int      @default(1)
  tags          String[]
  isActive      Boolean  @default(true)
  sourceKey     String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
  @@index([skill])
  @@index([difficulty])
  @@index([isActive])
}

model NihongoMockTestQuestion {
  id            String   @id @default(cuid())
  sourceKey     String   @unique
  originalId    Int?
  level         String
  testType      String
  section       String
  subCategory   String
  question      String
  options       Json
  correctAnswer String
  explanation   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  answers NihongoMockTestAnswer[]

  @@index([level])
  @@index([section])
  @@index([subCategory])
  @@index([isActive])
}

model NihongoMockTestAttempt {
  id                 String   @id @default(cuid())
  userId             String
  level              String
  status             String   @default("COMPLETED")
  totalQuestions     Int
  correctCount       Int
  scorePercent       Int
  readinessThreshold Int      @default(70)
  completedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers NihongoMockTestAnswer[]

  @@index([userId])
  @@index([level])
  @@index([scorePercent])
}

model NihongoMockTestAnswer {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String
  userAnswer String?
  isCorrect  Boolean

  attempt  NihongoMockTestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question NihongoMockTestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model UserNihongoProfile {
  id     String @id @default(cuid())
  userId String @unique

  currentLevel               String    @default("Absolute Beginner")
  targetLevel                String    @default("N4")
  weaknessTags               String[]
  strengthTags               String[]
  recommendedLessonIds       String[]
  recommendedCurriculumFocus String[]
  recommendedDailyPlan       String?
  nextLessonId               String?
  badgeId                    String?
  assessmentCompletedAt      DateTime?
  latestAssessmentId         String?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nextLesson NihongoLesson? @relation("NextNihongoLesson", fields: [nextLessonId], references: [id])
  badge      NihongoBadge?  @relation(fields: [badgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoBadge {
  id                  String  @id
  nameIndonesian      String
  nameJapanese        String
  archetype           String
  levelRequirement    String
  motivationalMessage String
  imageUrl            String?
  iconUrl             String?

  profiles           UserNihongoProfile[]
  assignedUsers      UserNihongoBadge[]
  assessmentSessions NihongoAssessmentSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserNihongoBadge {
  id                  String   @id @default(cuid())
  userId              String
  badgeId             String
  assessmentSessionId String?
  assignedAt          DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge NihongoBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model NihongoLessonTemplate {
  id          String   @id @default(cuid())
  lessonId    String
  variant     Int
  title       String
  contentJson Json
  contentMd   String?
  level       String?
  topic       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, variant])
  @@index([lessonId])
}

model NihongoLessonGeneratedContent {
  id          String   @id @default(cuid())
  lessonId    String
  userId      String?
  promptType  String
  contentJson Json
  contentMd   String?
  createdAt   DateTime @default(now())

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model NihongoLessonTutorMessage {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model FeatureUsage {
  id      String @id @default(cuid())
  userId  String
  appSlug String @default("nihongo")
  feature String

  count       Int       @default(0)
  periodStart DateTime  @default(now())
  periodEnd   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, appSlug, feature, periodStart])
  @@index([userId])
  @@index([feature])
}

model UserGameProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  totalXP               Int       @default(0)
  buildPoints           Int       @default(0)
  coins                 Int       @default(0)
  flashcardCorrectCount Int       @default(0)
  quizCorrectCount      Int       @default(0)
  mockTestCorrectCount  Int       @default(0)
  lessonCompletedCount  Int       @default(0)
  readingCompletedCount Int       @default(0)
  lastDailyBonusDate    DateTime?
  xpEarnedToday         Int       @default(0)
  xpTodayDate           DateTime?
  achievementsJson      Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReadingPassage {
  id String @id @default(cuid())

  title           String
  level           String
  topic           String
  contentJa       String
  contentId       String            @unique
  contentType     String            @default("READING")
  audioUrl        String?
  audioMimeType   String?
  durationSec     Int?
  kanjiJson       Json?
  romajiJson      Json?
  translationJson Json?
  vocabularyJson  Json
  questionsJson   Json
  answerKeyJson   Json?
  note            String?
  sourceType      ReadingSourceType @default(CACHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([topic])
  @@index([contentType])
  @@index([sourceType])
}

model NihongoLessonListeningAsset {
  id             String   @id @default(cuid())
  lessonId       String   @unique
  scriptJapanese String
  scriptRomaji   String?
  translationId  String?
  audioUrl       String?
  audioMimeType  String?
  audioProvider  String?
  durationSec    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model EnglishInterviewQuestion {
  id               String   @id @default(cuid())
  sourceKey        String   @unique
  order            Int
  prompt           String
  focusArea        String
  expectedDuration String?
  audioText        String
  audioBase64      String?
  audioMimeType    String?
  audioProvider    String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  answers EnglishInterviewAnswer[]

  @@index([order])
  @@index([isActive])
}

model EnglishInterviewAnswer {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  audioBase64   String
  audioMimeType String
  durationSec   Int
  fileName      String?
  transcription String?
  status        String   @default("SUBMITTED")
  submittedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question EnglishInterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  review   EnglishInterviewReview?

  @@index([userId])
  @@index([questionId])
  @@index([submittedAt])
}

model EnglishInterviewReview {
  id                 String   @id @default(cuid())
  answerId           String   @unique
  reviewerId         String
  englishLevel       String
  pronunciationScore Int?
  fluencyScore       Int?
  grammarScore       Int?
  vocabularyScore    Int?
  confidenceScore    Int?
  overallScore       Int?
  feedback           String
  recommendation     String?
  visibleToUser      Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  answer   EnglishInterviewAnswer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  reviewer User                   @relation("EnglishInterviewReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@index([englishLevel])
}

model PmpIttoProcess {
  id              String   @id @default(cuid())
  processName     String
  processGroup    String
  knowledgeArea   String
  domain          String?
  approach        String   @default("predictive")
  examVersion     String   @default("current")
  purpose         String
  whenToUse       String?
  simpleExample   String?
  agileHybridNote String?
  commonPitfall   String?
  studyTip        String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inputs  PmpIttoItem[] @relation("ProcessInputs")
  tools   PmpIttoItem[] @relation("ProcessTools")
  outputs PmpIttoItem[] @relation("ProcessOutputs")

  @@unique([processName, examVersion])
  @@index([processGroup])
  @@index([knowledgeArea])
  @@index([examVersion])
  @@index([isActive])
}

model PmpIttoItem {
  id            String   @id @default(cuid())
  name          String
  type          String
  description   String
  simpleExample String?
  examTip       String?
  relatedTerms  String[]
  examVersion   String   @default("both")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inputForId  String?
  toolForId   String?
  outputForId String?

  inputFor  PmpIttoProcess? @relation("ProcessInputs", fields: [inputForId], references: [id], onDelete: Cascade)
  toolFor   PmpIttoProcess? @relation("ProcessTools", fields: [toolForId], references: [id], onDelete: Cascade)
  outputFor PmpIttoProcess? @relation("ProcessOutputs", fields: [outputForId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([type])
  @@index([inputForId])
  @@index([toolForId])
  @@index([outputForId])
}

model PmpGlossaryTerm {
  id            String   @id @default(cuid())
  term          String
  acronym       String?
  category      String?
  definition    String
  simpleMeaning String?
  example       String?
  pmpMindset    String?
  relatedTerms  String[]
  approach      String   @default("general")
  examVersion   String   @default("both")
  difficulty    String   @default("medium")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([term, examVersion])
  @@index([category])
  @@index([approach])
  @@index([examVersion])
  @@index([difficulty])
  @@index([isActive])
}

model PmpKnowledgeArticle {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  category     String
  domain       String?
  approach     String   @default("general")
  examVersion  String   @default("both")
  summary      String
  content      String
  keyTakeaways String[]
  examples     Json?
  relatedTerms String[]
  studyTip     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([domain])
  @@index([approach])
  @@index([examVersion])
  @@index([isActive])
}

model PmpAiFeedback {
  id              String   @id @default(cuid())
  userId          String
  sourceType      String   @default("andromeda_chat")
  sourceRef       String?
  contentHash     String
  contentExcerpt  String
  rating          String
  comment         String?
  userQuestion    String?
  createdAt       DateTime @default(now())

  @@unique([userId, contentHash])
  @@index([userId])
  @@index([sourceType])
  @@index([rating])
  @@index([createdAt])
}

model PmpBrainDump {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model PmpLessonProgress {
  id             String    @id @default(cuid())
  userId         String
  lessonId       String
  status         String    @default("not_started")
  completedAt    DateTime?
  lastAccessedAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([status])
}

model PmpReadinessItem {
  id          String    @id @default(cuid())
  userId      String
  itemKey     String
  isComplete  Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, itemKey])
  @@index([userId])
  @@index([isComplete])
}

model ServerRouteMetric {
  id              String   @id @default(cuid())
  route           String
  method          String
  routeType       String   @default("api")
  riskLevel       String   @default("unknown")
  windowStart     DateTime
  count           Int      @default(0)
  totalDurationMs Int      @default(0)
  maxDurationMs   Int      @default(0)
  slowCount       Int      @default(0)
  errorCount      Int      @default(0)
  lastStatus      Int?
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([route, method, windowStart])
  @@index([windowStart])
  @@index([riskLevel])
  @@index([routeType])
}
