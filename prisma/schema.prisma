generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  TEACHER
  MODERATOR
}

enum AppStatus {
  ACTIVE
  DISABLED
  COMING_SOON
}

enum PaymentStatus {
  PENDING
  WAITING_VERIFICATION
  PAID
  REJECTED
  EXPIRED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELED
}

enum ReadingSourceType {
  CACHED
  AI_GENERATED
}

enum StoryArcGrade {
  GRADE_10
  GRADE_11
  GRADE_12
}

enum StoryArcTrack {
  SCHOOL_CORE
  STORY_MODE
  EXAM_LAB
}

enum StoryArcContentState {
  DRAFT
  VALIDATING
  IN_REVIEW
  APPROVED
  PUBLISHED
  SUPERSEDED
  ARCHIVED
}

enum StoryArcContentKind {
  LEARNING_ITEM
  ASSESSMENT
  VOCABULARY
  EXPRESSION
}

enum StoryArcSkill {
  LISTENING
  SPEAKING
  READING
  WRITING
  GRAMMAR
  VOCABULARY
}

enum StoryArcEvidenceClass {
  EXPOSURE
  PRACTICE
  ASSESSED_EVIDENCE
  RECALL_EVIDENCE
}

enum StoryArcAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  SCORED
  ABANDONED
}

enum StoryArcUnlockKind {
  VOCABULARY
  EXPRESSION
}

enum StoryArcClassStatus {
  ACTIVE
  ARCHIVED
}

enum StoryArcAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum StoryArcLibraryStorageProvider {
  DATABASE
  VERCEL_BLOB
}

enum StoryArcLibraryProcessingStatus {
  UPLOADED
  QUEUED
  PARSING
  INDEXING
  READY
  FAILED
}

enum StoryArcLibraryUploadIntentStatus {
  PENDING
  FINALIZING
  FINALIZED
  FAILED
  EXPIRED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  avatarUrl     String?

  learningReminderEnabled Boolean @default(false)
  learningReminderTime    String?
  learningGoal            String?

  role UserRole @default(USER)

  appAccess                    AppUserAccess[]
  lessonAccess                 LessonAccess[]
  payments                     PaymentTransaction[]
  subscriptions                Subscription[]
  paymentProofs                PaymentProof[]
  featureUsage                 FeatureUsage[]
  accessAudits                 AccessGrantAudit[]                @relation("AccessAuditActor")
  accounts                     Account[]
  sessions                     Session[]
  nihongoProfile               UserNihongoProfile?
  nihongoAssessments           NihongoAssessmentSession[]
  nihongoBadges                UserNihongoBadge[]
  nihongoMockAttempts          NihongoMockTestAttempt[]
  gameProfile                  UserGameProfile?
  gameKingdom                  GameKingdom?
  gameResourceLedgers          GameResourceLedger[]              @relation("GameLedgerUser")
  gameDailyCounters            GameLearningRewardDailyCounter[]
  communityRoomsCreated        CommunityRoom[]                   @relation("CommunityRoomCreator")
  communityMessages            CommunityMessage[]                @relation("CommunityMessageAuthor")
  communityReactions           CommunityMessageReaction[]        @relation("CommunityReactionUser")
  englishInterviewAnswers      EnglishInterviewAnswer[]
  englishInterviewReviews      EnglishInterviewReview[]          @relation("EnglishInterviewReviewer")
  analyticsEvents              AnalyticsEvent[]
  courseCertificates           CourseCertificate[]
  storyArcAttempts             StoryArcLearningAttempt[]
  storyArcEvidence             StoryArcLearningEvidence[]
  storyArcMastery              StoryArcMasteryProjection[]
  storyArcMasteryChanges       StoryArcMasteryProjectionChange[]
  storyArcPlayerState          StoryArcPlayerState?
  storyArcTransitions          StoryArcPlayerTransition[]
  storyArcUnlocks              StoryArcLearnerUnlock[]
  storyArcClassesTaught        StoryArcClass[]                   @relation("StoryArcClassTeacher")
  storyArcClassMemberships     StoryArcClassMember[]             @relation("StoryArcClassLearner")
  storyArcAssignmentsCreated   StoryArcAssignment[]              @relation("StoryArcAssignmentCreator")
  storyArcAssignmentProgress   StoryArcAssignmentProgress[]      @relation("StoryArcAssignmentLearner")
  storyArcLibraryUploads       StoryArcLibraryDocument[]         @relation("StoryArcLibraryUploader")
  storyArcLibraryUploadIntents StoryArcLibraryUploadIntent[]     @relation("StoryArcLibraryIntentUploader")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityRoom {
  id          String  @id @default(cuid())
  name        String
  description String?
  createdById String

  createdBy      User               @relation("CommunityRoomCreator", fields: [createdById], references: [id], onDelete: Cascade)
  messages       CommunityMessage[] @relation("CommunityRoomMessages")
  linkedMessages CommunityMessage[] @relation("LinkedCommunityRoom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([createdAt])
}

model GameKingdom {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  name                     String
  continent                String
  level                    Int       @default(1)
  castleLevel              Int       @default(1)
  xp                       Int       @default(0)
  resourcesJson            Json
  heroKey                  String    @default("ARJUNA")
  heroSelectedAt           DateTime?
  selectedAttackWeaponKey  String    @default("MOONLIGHT_KUNAI_STORM")
  selectedDefenseWeaponKey String    @default("SILVER_MOON_TOWER")
  shieldUntil              DateTime?
  lastDailyLoginRewardAt   DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers              GameResourceLedger[]
  armyUnits            GameArmyUnit[]
  battleLogsAsAttacker GameBattleLog[]      @relation("GameBattleAttacker")
  battleLogsAsDefender GameBattleLog[]      @relation("GameBattleDefender")
  cards                GameUserCard[]

  @@index([continent])
  @@index([xp])
  @@index([castleLevel])
}

model GameResourceLedger {
  id            String   @id @default(cuid())
  userId        String
  kingdomId     String
  sourceKey     String
  sourceType    String
  resourcesJson Json
  xp            Int      @default(0)
  metadata      Json?
  createdAt     DateTime @default(now())

  user    User        @relation("GameLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  kingdom GameKingdom @relation(fields: [kingdomId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceKey])
  @@index([kingdomId])
  @@index([sourceType])
  @@index([createdAt])
}

model GameArmyUnit {
  id              String   @id @default(cuid())
  kingdomId       String
  unitKey         String
  quantity        Int      @default(0)
  defenseQuantity Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  kingdom GameKingdom @relation(fields: [kingdomId], references: [id], onDelete: Cascade)

  @@unique([kingdomId, unitKey])
  @@index([kingdomId])
}

model GameBattleLog {
  id                     String    @id @default(cuid())
  attackerKingdomId      String
  defenderKingdomId      String
  continent              String
  result                 String
  attackerPower          Int
  defenderPower          Int
  stolenResourcesJson    Json
  casualtiesJson         Json
  attackerCasualtiesJson Json?
  defenderCasualtiesJson Json?
  snapshotJson           Json
  defenderSeenAt         DateTime?
  createdAt              DateTime  @default(now())

  attacker GameKingdom @relation("GameBattleAttacker", fields: [attackerKingdomId], references: [id], onDelete: Cascade)
  defender GameKingdom @relation("GameBattleDefender", fields: [defenderKingdomId], references: [id], onDelete: Cascade)

  @@index([attackerKingdomId])
  @@index([defenderKingdomId])
  @@index([continent])
  @@index([createdAt])
  @@index([defenderKingdomId, defenderSeenAt])
}

model GameUserCard {
  id        String   @id @default(cuid())
  kingdomId String
  cardKey   String
  quantity  Int      @default(1)
  equipped  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kingdom GameKingdom @relation(fields: [kingdomId], references: [id], onDelete: Cascade)

  @@unique([kingdomId, cardKey])
  @@index([kingdomId])
}

model GameLearningRewardDailyCounter {
  id             String   @id @default(cuid())
  userId         String
  counterDate    String
  flashcardCount Int      @default(0)
  quizCount      Int      @default(0)
  mockCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, counterDate])
  @@index([counterDate])
}

model CommunityMessage {
  id           String  @id @default(cuid())
  roomId       String
  authorId     String
  body         String
  replyToId    String?
  linkedRoomId String?

  room       CommunityRoom              @relation("CommunityRoomMessages", fields: [roomId], references: [id], onDelete: Cascade)
  author     User                       @relation("CommunityMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replyTo    CommunityMessage?          @relation("MessageReplies", fields: [replyToId], references: [id])
  replies    CommunityMessage[]         @relation("MessageReplies")
  linkedRoom CommunityRoom?             @relation("LinkedCommunityRoom", fields: [linkedRoomId], references: [id])
  reactions  CommunityMessageReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([authorId])
  @@index([replyToId])
  @@index([linkedRoomId])
  @@index([createdAt])
}

model CommunityMessageReaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  type      String @default("ONIGIRI")

  message CommunityMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation("CommunityReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([messageId, userId, type])
  @@index([messageId])
  @@index([userId])
}

model AnalyticsEvent {
  id            String  @id @default(cuid())
  userId        String?
  sessionId     String?
  eventType     String
  appSlug       String? @default("nihongo")
  pagePath      String?
  lessonId      String?
  quizId        String?
  flashcardDeck String?
  metadata      Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([appSlug])
  @@index([pagePath])
  @@index([lessonId])
  @@index([quizId])
  @@index([flashcardDeck])
  @@index([createdAt])
}

model PlatformApp {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  status      AppStatus @default(ACTIVE)

  users         AppUserAccess[]
  plans         SubscriptionPlan[]
  payments      PaymentTransaction[]
  subscriptions Subscription[]
  accessAudits  AccessGrantAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id          String  @id @default(cuid())
  key         String  @unique
  label       String
  value       String?
  valueType   String  @default("TEXT")
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppUserAccess {
  id     String @id @default(cuid())
  userId String
  appId  String

  status          String    @default("ACTIVE")
  billingPlan     String    @default("TRIAL")
  billingPeriod   String    @default("MONTHLY")
  accessStartsAt  DateTime  @default(now())
  accessExpiresAt DateTime?
  lastOpenedAt    DateTime?
  sourcePaymentId String?

  user User        @relation(fields: [userId], references: [id])
  app  PlatformApp @relation(fields: [appId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, appId])
  @@index([sourcePaymentId])
}

model SubscriptionPlan {
  id            String  @id @default(cuid())
  appId         String
  name          String
  code          String
  description   String?
  priceCents    Int
  currency      String  @default("IDR")
  durationDays  Int
  billingPeriod String  @default("MONTHLY")
  active        Boolean @default(true)

  app           PlatformApp          @relation(fields: [appId], references: [id], onDelete: Cascade)
  payments      PaymentTransaction[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, code])
  @@index([billingPeriod])
}

model Subscription {
  id              String  @id @default(cuid())
  userId          String
  appId           String
  planId          String?
  sourcePaymentId String? @unique

  status     SubscriptionStatus @default(TRIAL)
  startedAt  DateTime           @default(now())
  expiresAt  DateTime?
  canceledAt DateTime?

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  app  PlatformApp       @relation(fields: [appId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan? @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([appId])
  @@index([status])
}

model PaymentTransaction {
  id     String  @id @default(cuid())
  userId String
  appId  String
  planId String?

  provider     String    @default("MANUAL")
  providerRef  String?
  status       String    @default("PENDING")
  amountCents  Int
  currency     String    @default("IDR")
  durationDays Int
  paidAt       DateTime?
  rawPayload   String?

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  app   PlatformApp       @relation(fields: [appId], references: [id], onDelete: Cascade)
  plan  SubscriptionPlan? @relation(fields: [planId], references: [id])
  proof PaymentProof?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerRef])
}

model PaymentProof {
  id        String @id @default(cuid())
  paymentId String @unique
  userId    String

  fileUrl      String
  fileName     String?
  fileMimeType String?
  note         String?
  status       String    @default("WAITING_VERIFICATION")
  reviewedBy   String?
  reviewedAt   DateTime?

  payment PaymentTransaction @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model CourseCertificate {
  id            String   @id @default(cuid())
  userId        String
  appSlug       String
  courseName    String
  displayName   String
  certificateId String   @unique
  issuedAt      DateTime @default(now())
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, appSlug, courseName])
  @@index([userId])
  @@index([appSlug])
}

model LessonAccess {
  id       String @id @default(cuid())
  userId   String
  lessonId String

  status    String    @default("ACTIVE")
  grantedBy String?
  expiresAt DateTime?

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model AccessGrantAudit {
  id       String  @id @default(cuid())
  actorId  String?
  userId   String
  appId    String?
  lessonId String?
  action   String
  reason   String?
  metadata String?

  actor User?        @relation("AccessAuditActor", fields: [actorId], references: [id])
  app   PlatformApp? @relation(fields: [appId], references: [id])

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model NihongoLesson {
  id          String  @id @default(cuid())
  slug        String? @unique
  level       String
  title       String
  description String?
  order       Int
  track       String?
  module      String?
  lessonType  String?

  progress               NihongoLessonProgress[]
  access                 LessonAccess[]
  recommendedForProfiles UserNihongoProfile[]            @relation("NextNihongoLesson")
  templates              NihongoLessonTemplate[]
  generatedContents      NihongoLessonGeneratedContent[]
  tutorMessages          NihongoLessonTutorMessage[]
  listeningAsset         NihongoLessonListeningAsset?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoCharacterContent {
  id         String  @id @default(cuid())
  type       String
  level      String
  lessonSlug String
  char       String
  romaji     String?
  onyomi     String?
  kunyomi    String?
  meaning    String?
  order      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, level, char])
  @@index([lessonSlug])
  @@index([type, level])
}

model NihongoLessonProgress {
  id        String  @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model NihongoFlashcard {
  id String @id @default(cuid())

  category String
  deck     String
  level    String
  front    String
  back     String
  example  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoAssessmentSession {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("IN_PROGRESS")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  overallScore               Int?
  estimatedLevel             String?
  weaknessTags               String[]
  strengthTags               String[]
  recommendedCurriculumFocus String[]
  recommendedLessonIds       String[]
  recommendedDailyPlan       String?
  aiFeedbackIndonesian       String?
  encouragementJapanese      String?
  badgeId                    String?
  finalEvaluation            Json?

  pronunciationScore    Int?
  pronunciationFeedback Json?

  user    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers NihongoAssessmentAnswer[]
  badge   NihongoBadge?             @relation(fields: [badgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model NihongoAssessmentAnswer {
  id            String   @id @default(cuid())
  sessionId     String
  questionId    String
  category      String
  type          String
  prompt        String
  userAnswer    String?
  correctAnswer String?
  isCorrect     Boolean?
  score         Int      @default(0)
  maxScore      Int      @default(1)
  metadata      Json?

  session NihongoAssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([category])
}

model AssessmentQuestion {
  id            String   @id @default(cuid())
  level         String
  skill         String
  questionType  String
  prompt        String
  passage       String?
  options       Json
  correctAnswer String
  explanation   String
  difficulty    Int      @default(1)
  tags          String[]
  isActive      Boolean  @default(true)
  sourceKey     String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
  @@index([skill])
  @@index([difficulty])
  @@index([isActive])
}

model NihongoMockTestQuestion {
  id            String   @id @default(cuid())
  sourceKey     String   @unique
  originalId    Int?
  level         String
  testType      String
  section       String
  subCategory   String
  question      String
  options       Json
  correctAnswer String
  explanation   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  answers NihongoMockTestAnswer[]

  @@index([level])
  @@index([section])
  @@index([subCategory])
  @@index([isActive])
}

model NihongoMockTestAttempt {
  id                 String   @id @default(cuid())
  userId             String
  level              String
  status             String   @default("COMPLETED")
  totalQuestions     Int
  correctCount       Int
  scorePercent       Int
  readinessThreshold Int      @default(70)
  completedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers NihongoMockTestAnswer[]

  @@index([userId])
  @@index([level])
  @@index([scorePercent])
}

model NihongoMockTestAnswer {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String
  userAnswer String?
  isCorrect  Boolean

  attempt  NihongoMockTestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question NihongoMockTestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model UserNihongoProfile {
  id     String @id @default(cuid())
  userId String @unique

  currentLevel               String    @default("Absolute Beginner")
  targetLevel                String    @default("N4")
  weaknessTags               String[]
  strengthTags               String[]
  recommendedLessonIds       String[]
  recommendedCurriculumFocus String[]
  recommendedDailyPlan       String?
  nextLessonId               String?
  badgeId                    String?
  assessmentCompletedAt      DateTime?
  latestAssessmentId         String?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nextLesson NihongoLesson? @relation("NextNihongoLesson", fields: [nextLessonId], references: [id])
  badge      NihongoBadge?  @relation(fields: [badgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoBadge {
  id                  String  @id
  nameIndonesian      String
  nameJapanese        String
  archetype           String
  levelRequirement    String
  motivationalMessage String
  imageUrl            String?
  iconUrl             String?

  profiles           UserNihongoProfile[]
  assignedUsers      UserNihongoBadge[]
  assessmentSessions NihongoAssessmentSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserNihongoBadge {
  id                  String   @id @default(cuid())
  userId              String
  badgeId             String
  assessmentSessionId String?
  assignedAt          DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge NihongoBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model NihongoLessonTemplate {
  id          String   @id @default(cuid())
  lessonId    String
  variant     Int
  title       String
  contentJson Json
  contentMd   String?
  level       String?
  topic       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, variant])
  @@index([lessonId])
}

model NihongoLessonGeneratedContent {
  id          String   @id @default(cuid())
  lessonId    String
  userId      String?
  promptType  String
  contentJson Json
  contentMd   String?
  createdAt   DateTime @default(now())

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model NihongoLessonTutorMessage {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model FeatureUsage {
  id      String @id @default(cuid())
  userId  String
  appSlug String @default("nihongo")
  feature String

  count       Int       @default(0)
  periodStart DateTime  @default(now())
  periodEnd   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, appSlug, feature, periodStart])
  @@index([userId])
