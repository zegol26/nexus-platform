generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  TEACHER
  MODERATOR
}

enum AppStatus {
  ACTIVE
  DISABLED
  COMING_SOON
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  avatarUrl     String?

  learningReminderEnabled Boolean @default(false)
  learningReminderTime    String?
  learningGoal            String?

  role UserRole @default(USER)

  appAccess           AppUserAccess[]
  lessonAccess        LessonAccess[]
  payments            PaymentTransaction[]
  accessAudits        AccessGrantAudit[]         @relation("AccessAuditActor")
  accounts            Account[]
  sessions            Session[]
  nihongoProfile      UserNihongoProfile?
  nihongoAssessments  NihongoAssessmentSession[]
  nihongoBadges       UserNihongoBadge[]
  nihongoMockAttempts NihongoMockTestAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformApp {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  status      AppStatus @default(ACTIVE)

  users        AppUserAccess[]
  plans        SubscriptionPlan[]
  payments     PaymentTransaction[]
  accessAudits AccessGrantAudit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppUserAccess {
  id     String @id @default(cuid())
  userId String
  appId  String

  status          String    @default("ACTIVE")
  billingPlan     String    @default("TRIAL")
  billingPeriod   String    @default("MONTHLY")
  accessStartsAt  DateTime  @default(now())
  accessExpiresAt DateTime?
  lastOpenedAt    DateTime?

  user User        @relation(fields: [userId], references: [id])
  app  PlatformApp @relation(fields: [appId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, appId])
}

model SubscriptionPlan {
  id           String  @id @default(cuid())
  appId        String
  name         String
  code         String
  description  String?
  priceCents   Int
  currency     String  @default("IDR")
  durationDays Int
  active       Boolean @default(true)

  app      PlatformApp          @relation(fields: [appId], references: [id], onDelete: Cascade)
  payments PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([appId, code])
}

model PaymentTransaction {
  id     String  @id @default(cuid())
  userId String
  appId  String
  planId String?

  provider     String    @default("MANUAL")
  providerRef  String?
  status       String    @default("PENDING")
  amountCents  Int
  currency     String    @default("IDR")
  durationDays Int
  paidAt       DateTime?
  rawPayload   String?

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  app  PlatformApp       @relation(fields: [appId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan? @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerRef])
}

model LessonAccess {
  id       String @id @default(cuid())
  userId   String
  lessonId String

  status    String    @default("ACTIVE")
  grantedBy String?
  expiresAt DateTime?

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model AccessGrantAudit {
  id       String  @id @default(cuid())
  actorId  String?
  userId   String
  appId    String?
  lessonId String?
  action   String
  reason   String?
  metadata String?

  actor User?        @relation("AccessAuditActor", fields: [actorId], references: [id])
  app   PlatformApp? @relation(fields: [appId], references: [id])

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model NihongoLesson {
  id          String  @id @default(cuid())
  level       String
  title       String
  description String?
  order       Int
  track       String?
  module      String?
  lessonType  String?

  progress               NihongoLessonProgress[]
  access                 LessonAccess[]
  recommendedForProfiles UserNihongoProfile[]            @relation("NextNihongoLesson")
  templates              NihongoLessonTemplate[]
  generatedContents      NihongoLessonGeneratedContent[]
  tutorMessages          NihongoLessonTutorMessage[]
  listeningAsset         NihongoLessonListeningAsset?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoLessonProgress {
  id        String  @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model NihongoFlashcard {
  id String @id @default(cuid())

  category String
  deck     String
  level    String
  front    String
  back     String
  example  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoAssessmentSession {
  id          String    @id @default(cuid())
  userId      String
  status      String    @default("IN_PROGRESS")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  overallScore               Int?
  estimatedLevel             String?
  weaknessTags               String[]
  strengthTags               String[]
  recommendedCurriculumFocus String[]
  recommendedLessonIds       String[]
  recommendedDailyPlan       String?
  aiFeedbackIndonesian       String?
  encouragementJapanese      String?
  badgeId                    String?
  finalEvaluation            Json?

  pronunciationScore    Int?
  pronunciationFeedback Json?

  user    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers NihongoAssessmentAnswer[]
  badge   NihongoBadge?             @relation(fields: [badgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model NihongoAssessmentAnswer {
  id            String   @id @default(cuid())
  sessionId     String
  questionId    String
  category      String
  type          String
  prompt        String
  userAnswer    String?
  correctAnswer String?
  isCorrect     Boolean?
  score         Int      @default(0)
  maxScore      Int      @default(1)
  metadata      Json?

  session NihongoAssessmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([category])
}

model AssessmentQuestion {
  id            String   @id @default(cuid())
  level         String
  skill         String
  questionType  String
  prompt        String
  passage       String?
  options       Json
  correctAnswer String
  explanation   String
  difficulty    Int      @default(1)
  tags          String[]
  isActive      Boolean  @default(true)
  sourceKey     String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([level])
  @@index([skill])
  @@index([difficulty])
  @@index([isActive])
}

model NihongoMockTestQuestion {
  id            String   @id @default(cuid())
  sourceKey     String   @unique
  originalId    Int?
  level         String
  testType      String
  section       String
  subCategory   String
  question      String
  options       Json
  correctAnswer String
  explanation   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  answers NihongoMockTestAnswer[]

  @@index([level])
  @@index([section])
  @@index([subCategory])
  @@index([isActive])
}

model NihongoMockTestAttempt {
  id                 String   @id @default(cuid())
  userId             String
  level              String
  status             String   @default("COMPLETED")
  totalQuestions     Int
  correctCount       Int
  scorePercent       Int
  readinessThreshold Int      @default(70)
  completedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers NihongoMockTestAnswer[]

  @@index([userId])
  @@index([level])
  @@index([scorePercent])
}

model NihongoMockTestAnswer {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String
  userAnswer String?
  isCorrect  Boolean

  attempt  NihongoMockTestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question NihongoMockTestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model UserNihongoProfile {
  id     String @id @default(cuid())
  userId String @unique

  currentLevel               String    @default("Absolute Beginner")
  targetLevel                String    @default("N4")
  weaknessTags               String[]
  strengthTags               String[]
  recommendedLessonIds       String[]
  recommendedCurriculumFocus String[]
  recommendedDailyPlan       String?
  nextLessonId               String?
  badgeId                    String?
  assessmentCompletedAt      DateTime?
  latestAssessmentId         String?

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nextLesson NihongoLesson? @relation("NextNihongoLesson", fields: [nextLessonId], references: [id])
  badge      NihongoBadge?  @relation(fields: [badgeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NihongoBadge {
  id                  String  @id
  nameIndonesian      String
  nameJapanese        String
  archetype           String
  levelRequirement    String
  motivationalMessage String
  imageUrl            String?
  iconUrl             String?

  profiles           UserNihongoProfile[]
  assignedUsers      UserNihongoBadge[]
  assessmentSessions NihongoAssessmentSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserNihongoBadge {
  id                  String   @id @default(cuid())
  userId              String
  badgeId             String
  assessmentSessionId String?
  assignedAt          DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge NihongoBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model NihongoLessonTemplate {
  id          String   @id @default(cuid())
  lessonId    String
  variant     Int
  title       String
  contentJson Json
  contentMd   String?
  level       String?
  topic       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, variant])
  @@index([lessonId])
}

model NihongoLessonGeneratedContent {
  id          String   @id @default(cuid())
  lessonId    String
  userId      String?
  promptType  String
  contentJson Json
  contentMd   String?
  createdAt   DateTime @default(now())

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model NihongoLessonTutorMessage {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([userId])
}

model NihongoLessonListeningAsset {
  id             String   @id @default(cuid())
  lessonId       String   @unique
  scriptJapanese String
  scriptRomaji   String?
  translationId  String?
  audioUrl       String?
  audioMimeType  String?
  audioProvider  String?
  durationSec    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lesson NihongoLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}
