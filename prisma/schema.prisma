model StoryArcCurriculumSource {
  id               String   @id @default(cuid())
  sourceKey        String   @unique
  title            String
  authority        String
  reference        String?
  verificationNote String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  versions StoryArcCurriculumVersion[]
}

model StoryArcCurriculumVersion {
  id            String    @id @default(cuid())
  sourceId      String
  versionKey    String
  title         String
  effectiveFrom DateTime?
  retiredAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  source       StoryArcCurriculumSource    @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  competencies StoryArcCompetency[]
  objectives   StoryArcLearningObjective[]
  items        StoryArcContentItem[]

  @@unique([sourceId, versionKey])
  @@index([versionKey])
}

model StoryArcCompetency {
  id                  String   @id @default(cuid())
  curriculumVersionId String
  competencyKey       String
  title               String
  description         String
  authoritativeRef    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  curriculumVersion StoryArcCurriculumVersion   @relation(fields: [curriculumVersionId], references: [id], onDelete: Restrict)
  objectives        StoryArcLearningObjective[]

  @@unique([curriculumVersionId, competencyKey])
  @@index([competencyKey])
}

model StoryArcLearningObjective {
  id                  String        @id @default(cuid())
  curriculumVersionId String
  competencyId        String
  objectiveKey        String
  title               String
  primarySkill        StoryArcSkill
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  curriculumVersion StoryArcCurriculumVersion   @relation(fields: [curriculumVersionId], references: [id], onDelete: Restrict)
  competency        StoryArcCompetency          @relation(fields: [competencyId], references: [id], onDelete: Restrict)
  revisionLinks     StoryArcRevisionObjective[]

  @@unique([curriculumVersionId, objectiveKey])
  @@index([objectiveKey])
  @@index([competencyId])
}

model StoryArcContentItem {
  id                  String              @id @default(cuid())
  stableId            String              @unique
  curriculumVersionId String
  kind                StoryArcContentKind
  grade               StoryArcGrade
  track               StoryArcTrack
  phase               String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  curriculumVersion StoryArcCurriculumVersion @relation(fields: [curriculumVersionId], references: [id], onDelete: Restrict)
  revisions         StoryArcContentRevision[]
  attempts          StoryArcLearningAttempt[]

  @@index([grade, track])
  @@index([phase])
  @@index([kind])
}

model StoryArcContentRevision {
  id               String               @id @default(cuid())
  itemId           String
  revision         Int
  schemaVersion    String
  contentHash      String
  title            String
  state            StoryArcContentState @default(DRAFT)
  primarySkill     StoryArcSkill
  supportingSkills StoryArcSkill[]
  payload          Json
  validationReport Json?
  sourceMetadata   Json?
  createdById      String
  reviewedById     String?
  approvedById     String?
  reviewedAt       DateTime?
  approvedAt       DateTime?
  publishedAt      DateTime?
  retiredAt        DateTime?
  createdAt        DateTime             @default(now())

  item             StoryArcContentItem         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  objectives       StoryArcRevisionObjective[]
  attempts         StoryArcLearningAttempt[]
  evidence         StoryArcLearningEvidence[]
  unlocks          StoryArcLearnerUnlock[]
  transitions      StoryArcPlayerTransition[]
  classAssignments StoryArcAssignment[]

  @@unique([itemId, revision])
  @@unique([itemId, contentHash])
  @@index([state, publishedAt])
  @@index([contentHash])
}

model StoryArcClass {
  id        String              @id @default(cuid())
  name      String
  grade     StoryArcGrade
  section   String
  joinCode  String              @unique
  status    StoryArcClassStatus @default(ACTIVE)
  teacherId String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  teacher       User                          @relation("StoryArcClassTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  members       StoryArcClassMember[]
  assignments   StoryArcAssignment[]
  documents     StoryArcLibraryDocument[]
  uploadIntents StoryArcLibraryUploadIntent[]

  @@unique([teacherId, grade, section])
  @@index([teacherId, status])
  @@index([grade, section])
}

model StoryArcClassMember {
  id        String   @id @default(cuid())
  classId   String
  learnerId String
  joinedAt  DateTime @default(now())

  classroom StoryArcClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  learner   User          @relation("StoryArcClassLearner", fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([classId, learnerId])
  @@index([learnerId, joinedAt])
}

model StoryArcAssignment {
  id            String    @id @default(cuid())
  classId       String
  revisionId    String
  createdById   String
  title         String
  instructions  String?
  availableFrom DateTime
  dueAt         DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  classroom StoryArcClass                @relation(fields: [classId], references: [id], onDelete: Cascade)
  revision  StoryArcContentRevision      @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  createdBy User                         @relation("StoryArcAssignmentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  progress  StoryArcAssignmentProgress[]

  @@unique([classId, revisionId])
  @@index([classId, availableFrom])
  @@index([revisionId, availableFrom])
}

model StoryArcAssignmentProgress {
  id           String                   @id @default(cuid())
  assignmentId String
  learnerId    String
  status       StoryArcAssignmentStatus @default(ASSIGNED)
  startedAt    DateTime?
  completedAt  DateTime?
  score        Float?
  maxScore     Float?
  scorePercent Float?
  scoreSource  String?
  scoredAt     DateTime?
  updatedAt    DateTime                 @updatedAt
  createdAt    DateTime                 @default(now())

  assignment StoryArcAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  learner    User               @relation("StoryArcAssignmentLearner", fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, learnerId])
  @@index([learnerId, status])
}

model StoryArcLibraryDocument {
  id               String                          @id @default(cuid())
  classId          String
  uploadedById     String
  subject          String
  title            String
  summary          String
  fileName         String
  mimeType         String
  fileSize         Int
  fileData         Bytes?
  storageProvider  StoryArcLibraryStorageProvider  @default(DATABASE)
  blobPathname     String?                         @unique
  blobEtag         String?
  processingStatus StoryArcLibraryProcessingStatus @default(READY)
  finalizedAt      DateTime?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  classroom  StoryArcClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  uploadedBy User          @relation("StoryArcLibraryUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([classId, subject, createdAt])
  @@index([uploadedById, createdAt])
  @@index([storageProvider, processingStatus, createdAt])
}

model StoryArcLibraryUploadIntent {
  id               String                            @id @default(cuid())
  documentId       String                            @unique
  classId          String
  uploadedById     String
  subject          String
  title            String
  summary          String
  fileName         String
  expectedPathname String                            @unique
  expectedFileSize Int
  expectedMimeType String
  status           StoryArcLibraryUploadIntentStatus @default(PENDING)
  expiresAt        DateTime
  finalizedAt      DateTime?
  failureReason    String?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt

  classroom  StoryArcClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  uploadedBy User          @relation("StoryArcLibraryIntentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([classId, status, expiresAt])
  @@index([uploadedById, status, expiresAt])
}

model StoryArcRevisionObjective {
  id          String  @id @default(cuid())
  revisionId  String
  objectiveId String
  isPrimary   Boolean @default(false)

  revision  StoryArcContentRevision   @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  objective StoryArcLearningObjective @relation(fields: [objectiveId], references: [id], onDelete: Restrict)

  @@unique([revisionId, objectiveId])
  @@index([objectiveId])
}

model StoryArcLearningAttempt {
  id             String                @id @default(cuid())
  userId         String
  itemId         String
  revisionId     String
  mode           String
  status         StoryArcAttemptStatus @default(IN_PROGRESS)
  idempotencyKey String
  startedAt      DateTime              @default(now())
  submittedAt    DateTime?

  user     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  item     StoryArcContentItem        @relation(fields: [itemId], references: [id], onDelete: Restrict)
  revision StoryArcContentRevision    @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  evidence StoryArcLearningEvidence[]

  @@unique([userId, idempotencyKey])
  @@index([userId, itemId])
  @@index([revisionId])
}

model StoryArcLearningEvidence {
  id               String                @id @default(cuid())
  attemptId        String
  userId           String
  revisionId       String
  evidenceClass    StoryArcEvidenceClass
  competencyKey    String
  objectiveKey     String
  skill            StoryArcSkill
  rubricRevisionId String?
  rawScore         Float?
  maxScore         Float?
  normalizedScore  Float?
  confidence       Float?
  evaluatorType    String
  evaluatorRef     String?
  metadata         Json?
  occurredAt       DateTime              @default(now())

  attempt  StoryArcLearningAttempt          @relation(fields: [attemptId], references: [id], onDelete: Restrict)
  user     User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  revision StoryArcContentRevision          @relation(fields: [revisionId], references: [id], onDelete: Restrict)
  change   StoryArcMasteryProjectionChange?

  @@index([userId, skill, occurredAt])
  @@index([evidenceClass])
  @@index([objectiveKey])
}

model StoryArcMasteryProjection {
  id               String        @id @default(cuid())
  userId           String
  skill            StoryArcSkill
  score            Float         @default(0)
  band             String        @default("NOT_ENOUGH_EVIDENCE")
  evidenceThrough  DateTime?
  algorithmVersion String
  updatedAt        DateTime      @updatedAt
  createdAt        DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([skill, score])
}

model StoryArcMasteryProjectionChange {
  id               String        @id @default(cuid())
  userId           String
  skill            StoryArcSkill
  evidenceId       String        @unique
  beforeScore      Float
  afterScore       Float
  algorithmVersion String
  reasonCode       String
  createdAt        DateTime      @default(now())

  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidence StoryArcLearningEvidence @relation(fields: [evidenceId], references: [id], onDelete: Restrict)

  @@index([userId, skill, createdAt])
}

model StoryArcPlayerState {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentArcId      String
  currentEpisodeId  String
  currentSceneId    String
  checkpointId      String
  completedNodeIds  String[]
  questState        Json
  relationshipState Json
  decisionState     Json
  storyXp           Int      @default(0)
  storyLevel        Int      @default(1)
  stateVersion      Int      @default(1)
  lastSavedAt       DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transitions StoryArcPlayerTransition[]
}

model StoryArcPlayerTransition {
  id                String   @id @default(cuid())
  userId            String
  playerStateId     String
  idempotencyKey    String
  actionType        String
  sourceRevisionId  String
  sourceNodeId      String
  payload           Json
  xpDelta           Int      @default(0)
  stateVersionAfter Int
  createdAt         DateTime @default(now())

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  playerState    StoryArcPlayerState     @relation(fields: [playerStateId], references: [id], onDelete: Cascade)
  sourceRevision StoryArcContentRevision @relation(fields: [sourceRevisionId], references: [id], onDelete: Restrict)

  @@unique([userId, idempotencyKey])
  @@index([playerStateId, createdAt])
  @@index([sourceRevisionId])
}

model StoryArcLearnerUnlock {
  id               String             @id @default(cuid())
  userId           String
  kind             StoryArcUnlockKind
  entryKey         String
  sourceRevisionId String
  sourceIntentKey  String
  futureRecallKey  String
  unlockedAt       DateTime           @default(now())

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceRevision StoryArcContentRevision @relation(fields: [sourceRevisionId], references: [id], onDelete: Restrict)

  @@unique([userId, kind, entryKey])
  @@index([userId, unlockedAt])
  @@index([futureRecallKey])
}
