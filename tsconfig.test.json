{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "lib/admin/**/*.ts",
    "lib/nexus/access-policy.ts",
    "lib/nihongo/lesson-cache-policy.ts",
    "lib/platform/payment-policy.ts",
    "lib/platform/settings-policy.ts"
  ],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
