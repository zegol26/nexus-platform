# Nexus Platform — environment variables
# Copy this file to .env and fill in real values.

# ----- Core ---------------------------------------------------------
DATABASE_URL=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ----- Admin bootstrap (only used by prisma seed) -------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ----- AI Tutor + Voice Conversation --------------------------------
# Required for AI Tutor text replies, voice transcription (Whisper),
# and the OpenAI TTS fallback when ElevenLabs is not configured.
OPENAI_API_KEY=

# Optional: pin specific OpenAI models (sane defaults shipped in code).
# Ai-chan is voiced as an anime-schoolgirl-style young female sensei.
# The default voice "coral" is the lightest/brightest young-female
# voice OpenAI ships and lands closest to that wibu character feel.
# "shimmer" or "nova" are acceptable alternates; avoid
# "onyx"/"echo"/"ash"/"sage" (skew older or male).
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_NIHONGO_TTS_VOICE=coral

# Optional: ElevenLabs is the preferred TTS provider for Ai-chan voice.
# If both ELEVENLABS_API_KEY and ELEVENLABS_VOICE_ID are set, the voice
# endpoint uses ElevenLabs first and only falls back to OpenAI on error.
# Leave both blank to skip ElevenLabs entirely.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ----- Optional flags -----------------------------------------------
ENABLE_OPENAI_LESSON_TEMPLATE_GENERATION=false
ENABLE_OPENAI_TTS=false
